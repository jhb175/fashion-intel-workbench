# ===========================================
# Fashion Intel Workbench - Environment Config
# ===========================================
# Copy this file to .env and update values as needed.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fashion_intel

# --- Database (used by backend & celery-worker) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/fashion_intel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Encryption (Fernet key for API key storage) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-in-production

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
